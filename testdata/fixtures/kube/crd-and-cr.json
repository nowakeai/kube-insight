{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "apiextensions.k8s.io/v1",
      "kind": "CustomResourceDefinition",
      "metadata": {"name": "widgets.example.com", "uid": "crd-widgets"},
      "spec": {
        "group": "example.com",
        "names": {"kind": "Widget", "plural": "widgets", "singular": "widget"},
        "scope": "Namespaced",
        "conversion": {
          "strategy": "Webhook",
          "webhook": {
            "clientConfig": {
              "service": {"name": "api", "namespace": "default", "path": "/convert"}
            },
            "conversionReviewVersions": ["v1"]
          }
        },
        "versions": [
          {
            "name": "v1",
            "served": true,
            "storage": true,
            "schema": {
              "openAPIV3Schema": {
                "type": "object",
                "description": "Widget configures an example controller.",
                "properties": {
                  "spec": {
                    "type": "object",
                    "properties": {
                      "replicas": {"type": "integer", "description": "Number of replicas."},
                      "endpoint": {"type": "string", "description": "External endpoint for the widget."},
                      "tokenSecretRef": {"type": "string", "description": "Secret name containing an API token."}
                    }
                  }
                }
              }
            }
          }
        ]
      }
    },
    {
      "apiVersion": "example.com/v1",
      "kind": "Widget",
      "metadata": {"name": "api-widget", "namespace": "default", "uid": "widget-api"},
      "spec": {"replicas": 2, "endpoint": "https://widget.internal.example.com", "tokenSecretRef": "api-secret"},
      "status": {"phase": "Ready"}
    }
  ]
}
