{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "networking.k8s.io/v1",
      "kind": "Ingress",
      "metadata": {"name": "api", "namespace": "default", "uid": "ing-api"},
      "spec": {
        "rules": [
          {
            "host": "api.example.invalid",
            "http": {
              "paths": [
                {
                  "path": "/",
                  "pathType": "Prefix",
                  "backend": {"service": {"name": "api", "port": {"number": 80}}}
                }
              ]
            }
          }
        ]
      }
    },
    {
      "apiVersion": "gateway.networking.k8s.io/v1",
      "kind": "GatewayClass",
      "metadata": {"name": "internal", "uid": "gwc-internal"},
      "spec": {"controllerName": "example.invalid/gateway-controller"}
    },
    {
      "apiVersion": "gateway.networking.k8s.io/v1",
      "kind": "Gateway",
      "metadata": {"name": "api-gateway", "namespace": "default", "uid": "gw-api"},
      "spec": {
        "gatewayClassName": "internal",
        "listeners": [{"name": "http", "protocol": "HTTP", "port": 80}]
      }
    },
    {
      "apiVersion": "gateway.networking.k8s.io/v1",
      "kind": "HTTPRoute",
      "metadata": {"name": "api-route", "namespace": "default", "uid": "httproute-api"},
      "spec": {
        "parentRefs": [{"name": "api-gateway"}],
        "rules": [{"backendRefs": [{"name": "api", "port": 80}]}]
      }
    },
    {
      "apiVersion": "apiregistration.k8s.io/v1",
      "kind": "APIService",
      "metadata": {"name": "v1alpha1.metrics.example.invalid", "uid": "apisvc-metrics"},
      "spec": {
        "group": "metrics.example.invalid",
        "version": "v1alpha1",
        "service": {"name": "api", "namespace": "default"}
      }
    }
  ]
}
