{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {"name": "api", "namespace": "default", "uid": "deploy-api", "generation": 2},
      "spec": {
        "replicas": 3,
        "selector": {"matchLabels": {"app.kubernetes.io/name": "api"}},
        "template": {
          "metadata": {"labels": {"app.kubernetes.io/name": "api"}},
          "spec": {
            "serviceAccountName": "api",
            "containers": [
              {
                "name": "app",
                "image": "registry.example.invalid/api:v1.2.3",
                "envFrom": [{"secretRef": {"name": "api-secret"}}]
              }
            ],
            "volumes": [{"name": "config", "configMap": {"name": "api-config"}}]
          }
        }
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "ReplicaSet",
      "metadata": {
        "name": "api-abc123",
        "namespace": "default",
        "uid": "rs-api",
        "ownerReferences": [{"apiVersion": "apps/v1", "kind": "Deployment", "name": "api", "uid": "deploy-api"}]
      },
      "spec": {"replicas": 3}
    },
    {
      "apiVersion": "networking.k8s.io/v1",
      "kind": "NetworkPolicy",
      "metadata": {"name": "api-deny", "namespace": "default", "uid": "netpol-api"},
      "spec": {"podSelector": {"matchLabels": {"app.kubernetes.io/name": "api"}}, "policyTypes": ["Ingress"]}
    },
    {
      "apiVersion": "autoscaling/v2",
      "kind": "HorizontalPodAutoscaler",
      "metadata": {"name": "api", "namespace": "default", "uid": "hpa-api"},
      "spec": {
        "minReplicas": 2,
        "maxReplicas": 10,
        "scaleTargetRef": {"apiVersion": "apps/v1", "kind": "Deployment", "name": "api"}
      }
    },
    {
      "apiVersion": "batch/v1",
      "kind": "Job",
      "metadata": {"name": "api-migration", "namespace": "default", "uid": "job-api"},
      "status": {"succeeded": 1}
    }
  ]
}
